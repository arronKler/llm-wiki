filters:
  and:
    - 'file.inFolder("wiki")'
    - 'file.ext == "md"'
    - 'file.name != "_index"'
    - 'file.name != "_schema"'
    - 'file.name != "_catalog"'
    - 'file.name != "_sources"'
    - 'file.name != "_lint"'
properties:
  file.name:
    displayName: Page
  type:
    displayName: Type
  domains:
    displayName: Domains
  status:
    displayName: Status
  classification:
    displayName: Classification
  updated:
    displayName: Updated
  as_of:
    displayName: As of
  review_after:
    displayName: Review after
  confidence:
    displayName: Confidence
  sources:
    displayName: Sources
views:
  - type: table
    name: All knowledge
    groupBy:
      property: type
      direction: ASC
    order:
      - file.name
      - type
      - domains
      - status
      - updated
      - as_of
      - confidence
      - sources
  - type: table
    name: Needs review
    filters:
      or:
        - 'status == "needs-review"'
        - 'status == "conflicted"'
        - 'review_after <= today()'
    order:
      - file.name
      - status
      - review_after
      - as_of
      - sources
  - type: table
    name: Recently updated
    filters:
      and:
        - 'updated >= today() - "30d"'
    order:
      - file.name
      - type
      - updated
      - status
